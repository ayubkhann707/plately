generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"

}

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  password             String
  createdAt            DateTime       @default(now())

  nickname             String?
  avatarUrl            String?
  preferredUnits       String         @default("metric")
  preferredIngredients String[]       @default([])
  avoidedIngredients   String[]       @default([])

  planItems            MealPlanItem[]
  posts                Post[]
  saves                Save[]
  likes                Like[]
  pantryItems          PantryItem[]
  groceryShares        GroceryShare[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String
  imageUrl  String?
  creatorId String
  tags      String[]
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  creator   User     @relation(fields: [creatorId], references: [id])
  recipe    Recipe?
  saves     Save[]
  likes     Like[]

  @@index([creatorId])
}

model Recipe {
  id          String         @id @default(cuid())
  postId      String         @unique
  servings    Int?
  timeMinutes Int?
  ingredients Ingredient[]
  planItems   MealPlanItem[]
  post        Post           @relation(fields: [postId], references: [id])
  steps       Step[]
}

model Ingredient {
  id       String  @id @default(cuid())
  recipeId String
  name     String
  quantity Float?
  unit     String?
  recipe   Recipe  @relation(fields: [recipeId], references: [id])

  @@index([recipeId])
}

model Step {
  id       String @id @default(cuid())
  recipeId String
  order    Int
  text     String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  @@index([recipeId])
}

model Save {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, postId])
  @@index([postId])
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, postId])
  @@index([postId])
}

model MealPlanItem {
  id              String   @id @default(cuid())
  userId          String
  recipeId        String
  date            DateTime
  mealType        String   @default("Lunch")
  plannedServings Int?
  recipe          Recipe   @relation(fields: [recipeId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([recipeId])
}

model PantryItem {
  id     String @id @default(cuid())
  userId String
  name   String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
}

model GroceryShare {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  data      Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([token])
}
